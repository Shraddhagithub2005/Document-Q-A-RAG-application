# Copy this file to .env and fill in your values. Never commit the real .env file.

# Required for /ask to generate answers. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Which Claude model to use.
CLAUDE_MODEL=claude-sonnet-4-6

# Optional: protects your endpoints. If set, requests must include header:
#   X-API-Key: <this value>
APP_API_KEY=

# Where the vector database is persisted on disk.
CHROMA_DIR=./chroma_db

# Chunking tuning (usually fine to leave as default).
CHUNK_SIZE=800
CHUNK_OVERLAP=150
DEFAULT_TOP_K=4
